        },
        {
            "type": "path",
            "url": "../workflows"
        },
        {
            "type": "path",
            "url": "../api"
        },
        {
            "type": "path",
            "url": "../seo"
        },
        {
            "type": "path",
            "url": "../ssr"
        },
        {
            "type": "path",
            "url": "../cli"
        }
    ]
}
