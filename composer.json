        "waaseyaa/path": "^0.1.0-alpha.269",
        "waaseyaa/menu": "^0.1.0-alpha.269",
        "waaseyaa/workflows": "^0.1.0-alpha.269",
        "waaseyaa/api": "^0.1.0-alpha.269",
        "waaseyaa/seo": "^0.1.0-alpha.269",
        "waaseyaa/ssr": "^0.1.0-alpha.269",
        "waaseyaa/cli": "^0.1.0-alpha.269"
