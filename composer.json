{
    "name": "waaseyaa/cms",
    "description": "Waaseyaa — complete headless CMS with admin and CLI.",
    "type": "metapackage",
    "license": "GPL-2.0-or-later",
    "require": {
        "waaseyaa/core": "^0.1.0-alpha.269",
        "waaseyaa/node": "^0.1.0-alpha.269",
        "waaseyaa/taxonomy": "^0.1.0-alpha.269",
